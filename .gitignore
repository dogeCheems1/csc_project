# ============================================================
# ML Project - CSC (Chinese Spelling Correction)
# ============================================================

# 模型权重文件（体积过大，488MB/个，不上传 GitHub）
*.bin
*.pt
*.ckpt
*.safetensors
*.pth
*.h5

# TensorBoard 事件文件（不需要备份）
events.out.tfevents.*

# 中间训练检查点目录（过多冗余文件，不上传）
macro_correct/output/text_correction/stage1_confirm/
macro_correct/output/text_correction/smoke_test/
macro_correct/output/text_correction/smoke_test2/
macro_correct/output/text_correction/smoke_test3/
